# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# Transactional email (server-only). Never use VITE_RESEND_API_KEY.
# For local Resend testing, EMAIL_FROM can be "Stanza <onboarding@resend.dev>".
RESEND_API_KEY=
EMAIL_FROM=
APP_BASE_URL=http://localhost:3000

# VITE_API_BASE_URL: Browser API origin used by production preview/static frontend builds.
# Use http://localhost:3000 when previewing the Vite frontend against the Express backend.
VITE_API_BASE_URL=

# Public deployment origin used by metadata tooling. Do not include secrets.
VITE_PUBLIC_APP_URL=https://stanza-demo.onrender.com

# Set to false on a real production deployment to hide public demo account credentials.
VITE_ENABLE_DEMO_LOGIN=false

# Demo-only server safeguards. Keep disabled outside an isolated demo database.
STANZA_DEMO_ENV=false
ENABLE_PORTFOLIO_DEMO_SESSION=false
ALLOW_DEMO_DATA_MUTATION=false
DEMO_DATABASE_ALLOWLIST=
DEMO_DATABASE_NAME=
DEMO_RESET_CONFIRM=
# Required only when seeding the isolated demo database; never log or expose it.
DEMO_PASSWORD=

# QA/demo mutation guard. Required by smoke and Hiring integration scripts.
ALLOW_TEST_DATA_MUTATION=false
TEST_TARGET_ALLOWLIST=
TEST_DATABASE_ALLOWLIST=
ALLOW_NONLOCAL_TEST_TARGET=false
ALLOW_PRODUCTION_TEST_TARGET=false
TEST_DATA_NONINTERACTIVE=false
TEST_DATA_CONFIRM=

# DATABASE_URL: PostgreSQL connection string used by HR persistence endpoints.
DATABASE_URL=

# DATABASE_SSL: Set to true for hosted PostgreSQL providers that require SSL.
DATABASE_SSL=
DATABASE_SSL_CA=
# Number of trusted reverse-proxy hops in front of Express. Keep 0 when clients
# connect directly; set to the exact deployment topology when behind a proxy.
# Never increase this to accept arbitrary client-supplied X-Forwarded-For.
TRUST_PROXY_HOPS=0

# WebAuthn/passkey relying party settings.
# Localhost:
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGIN=http://localhost:3000
# Cloudflare tunnel / production must match the exact HTTPS origin used in the browser.
WEBAUTHN_RP_NAME=Stanza
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# CORS_ALLOWED_ORIGINS: Optional comma-separated list of browser origins allowed to call the API.
CORS_ALLOWED_ORIGINS=

# DEV_AUTH_HEADERS: Optional local-only escape hatch for legacy x-employee-id/x-tenant-id headers.
# Leave unset in production.
DEV_AUTH_HEADERS=

# MAPTILER_KEY: Server-only key used by /api/map-tiles to proxy map tiles.
# Do not prefix this with VITE_; VITE_ variables are exposed to browser code.
MAPTILER_KEY=

# VITE_MAPTILER_KEY: Public browser map key for MapLibre/MapTiler signup maps.
VITE_MAPTILER_KEY=

# MAPTILER_MAP_ID: Optional MapTiler map style id. Defaults to streets-v4.
MAPTILER_MAP_ID=

# Redis connection used by BullMQ background jobs. REDIS_URL takes precedence and
# supports redis:// for local/hosted Redis and rediss:// for TLS providers such as Upstash.
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JSON_BODY_LIMIT: Optional Express JSON body limit, e.g. 1mb.
JSON_BODY_LIMIT=

# Local avatar storage. This directory is suitable for development only; use a
# durable mounted volume or object-storage adapter in production.
PROFILE_IMAGE_DIRECTORY=uploads/profile-images

# Local Company Feed image storage. Files are re-encoded as WebP and served
# through authenticated tenant-scoped API routes, never as a public directory.
COMPANY_FEED_IMAGE_DIRECTORY=uploads/company-feed

# Local backend smoke test credentials. These values are read only by scripts/smoke-test.ts.
# Use a dedicated local hr_admin account and never commit real credentials.
SMOKE_TEST_EMAIL=
SMOKE_TEST_PASSWORD=
SMOKE_TEST_BASE_URL=http://localhost:3000

# Optional security-test fixtures. Use dedicated local accounts only.
SECURITY_TEST_ADMIN_EMAIL=
SECURITY_TEST_ADMIN_PASSWORD=
SECURITY_TEST_EMPLOYEE_EMAIL=
SECURITY_TEST_EMPLOYEE_PASSWORD=
SECURITY_TEST_BASE_URL=http://localhost:3000
