# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL connection string used by HR persistence endpoints.
DATABASE_URL="postgresql://user:password@localhost:5432/horizon_hr"

# DATABASE_SSL: Set to true for hosted PostgreSQL providers that require SSL.
DATABASE_SSL="false"

# MAPTILER_KEY: Server-only key used by /api/map-tiles to proxy map tiles.
# Do not prefix this with VITE_; VITE_ variables are exposed to browser code.
MAPTILER_KEY="MY_MAPTILER_KEY"

# MAPTILER_MAP_ID: Optional MapTiler map style id. Defaults to streets-v4.
MAPTILER_MAP_ID="streets-v4"

# REDIS_HOST / REDIS_PORT: Redis connection used by BullMQ background jobs.
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
