{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "tsx server.ts",
    "dev:worker": "tsx watch src/workers/hr-worker.ts",
    "dev": "concurrently -n \"Server,Worker\" -c \"cyan,green\" \"npm:dev:server\" \"npm:dev:worker\"",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:smoke": "tsx scripts/smoke-test.ts",
    "test:security": "tsx scripts/security-test.ts",
    "test:hiring": "tsx scripts/hiring-rules-test.ts",
    "test:hiring:integration": "tsx scripts/hiring-integration-test.ts",
    "db:seed:demo": "tsx scripts/seed-demo.ts",
    "db:reset:demo": "tsx scripts/reset-demo.ts",
    "assets:pwa": "node scripts/generate-pwa-icons.mjs",
    "analyze": "vite build --mode analyze",
    "security:audit": "npm audit",
    "check": "npm run lint && npm run build && npm audit",
    "check:security": "npm run lint && npm run build && npm audit && npm run test:security"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@lexical/history": "^0.46.0",
    "@lexical/link": "^0.46.0",
    "@lexical/list": "^0.46.0",
    "@lexical/react": "^0.46.0",
    "@lexical/rich-text": "^0.46.0",
    "@lexical/selection": "^0.46.0",
    "@lexical/utils": "^0.46.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/rapier": "^2.2.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "lexical": "^0.46.0",
    "lucide-react": "^0.546.0",
    "maplibre-gl": "^5.24.0",
    "meshline": "^3.3.1",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "resend": "^6.17.2",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "esbuild": "^0.25.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
